# Copy this to .env and fill in your values

# Flask Settings
SECRET_KEY=your-secret-key-change-this
DEBUG=True

# Database (use SQLite for development)
DATABASE_URL=sqlite:///instance/database.db

# For PostgreSQL:
# DATABASE_URL=postgresql://username:password@localhost/grabpic

# Face Recognition
FACE_DETECTION_MODEL=hog  # or 'cnn' for better accuracy (slower)
FACE_MATCH_THRESHOLD=0.6

# AWS S3 (optional - leave empty for local storage)
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
AWS_BUCKET=

# Encryption key for sensitive data (optional)
ENCRYPTION_KEY=